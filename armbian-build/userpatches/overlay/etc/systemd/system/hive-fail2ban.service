[Unit]
Description=Hive Network Node fail2ban Setup
Documentation=https://www.fail2ban.org/
After=network.target ufw.service hive-firewall.service
Before=ssh.service
Wants=network.target
ConditionPathExists=!/var/lib/hive/fail2ban-configured

[Service]
Type=oneshot
ExecStart=/usr/local/bin/setup-fail2ban.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
User=root
Group=root
ExecStartPost=/bin/bash -c 'mkdir -p /var/lib/hive && touch /var/lib/hive/fail2ban-configured'

[Install]
WantedBy=multi-user.target