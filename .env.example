# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ===== Cloudflare Tunnel =====
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_DOMAIN=yourdomain.com          # 节点 URL: hive-<mac6>.yourdomain.com

# ===== Tailscale =====
# 使用 OAuth Client Secret（不过期），而非 Auth Key（最多 90 天）
# 创建步骤：
#   1. Tailscale 控制台 → Settings → OAuth clients → Generate OAuth client
#   2. Scopes 勾选：devices:write（设备注册）+ devices:read（API 查询）
#   3. Tags 填写：tag:hive（与下方 --advertise-tags 保持一致）
#   4. 将生成的 Client Secret（tskey-client-xxxxx）填到下方
# 注意：必须在 ACL Policy 中预先声明该 tag，否则注册时会报错
#   "tagOwners": { "tag:hive": ["autogroup:admin"] }
TAILSCALE_OAUTH_SECRET=tskey-client-xxxxx

# ===== EasyTier =====
EASYTIER_NETWORK_NAME=hive
EASYTIER_SECRET=
# 中继节点，逗号分隔。单 peer 填一个；多 peer 示例：relay1.example.com,relay2.example.com 或 tcp://relay1:11010,tcp://relay2:11010
EASYTIER_PEERS=

# ===== FRP 服务端 =====
FRP_SERVER_ADDR=your-vps.example.com
FRP_SERVER_PORT=7000
FRP_AUTH_TOKEN=

# ===== 预编译二进制版本（可选，留空或 latest 使用最新）=====
# XRAY_VER/CLOUDFLARED_VER/FRP_VER/EASYTIER_VER 会被 scripts/download-binaries.sh 使用
XRAY_VER=latest
CLOUDFLARED_VER=latest
FRP_VER=0.67.0
EASYTIER_VER=v2.5.0

# ===== Node Registry（可选，留空则跳过注册）=====
# 填写到 /api 这一级（nginx 二级目录），末尾不加 /
# 节点调用：POST ${NODE_REGISTRY_URL}/nodes/register
NODE_REGISTRY_URL=https://yourdomain.com/api

# ===== Node Registry 服务端（部署在管理 VPS 上）=====
# 监听地址（127.0.0.1:8080 配合 CF Tunnel 或 nginx 反代）
REGISTRY_LISTEN_ADDR=127.0.0.1:8080

# MySQL 连接（使用服务器自带 MySQL 9）
REGISTRY_MYSQL_HOST=127.0.0.1
REGISTRY_MYSQL_PORT=3306
REGISTRY_MYSQL_USER=hive
REGISTRY_MYSQL_PASSWORD=
REGISTRY_MYSQL_DB=hive_registry

# 连接池（小规模部署默认即可，按需调整）
REGISTRY_DB_MAX_OPEN=10
REGISTRY_DB_MAX_IDLE=3

# xray 路径（需与节点 xray config 中的 path 一致）
REGISTRY_XRAY_PATH=ray

# 管理 API 认证（PATCH/DELETE 接口；留空则关闭认证）
REGISTRY_API_SECRET=

# ===== 镜像预设账号密码（避免首次启动交互）=====
# 留空将使用默认值：root/1234
DEFAULT_ROOT_PASSWORD=1234

# Grafana 管理员密码
GRAFANA_PASSWORD=changeme

# ===== 监控面板访问地址（与 nginx server_name 一致）=====
GRAFANA_ROOT_URL=https://example.com/grafana
PROMETHEUS_EXTERNAL_URL=https://example.com/prometheus
