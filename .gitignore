# 密钥和敏感配置
.env
*.secret
*.key
*.pem
*.p12

# Armbian 框架本体（由 scripts/setup-armbian.sh clone，不入库）
# 仅追踪 armbian-build/userpatches/ 下的自定义文件
armbian-build/*
!armbian-build/userpatches/

# 渲染后的实际配置（含密钥，由 build.sh 生成，不入库）
armbian-build/userpatches/overlay/etc/hive/config.env
armbian-build/userpatches/overlay/etc/frp/frpc.toml

# 预编译二进制（由 scripts/download-binaries.sh 下载，不入库）
armbian-build/userpatches/overlay/usr/local/bin/xray
armbian-build/userpatches/overlay/usr/local/bin/cloudflared
armbian-build/userpatches/overlay/usr/local/bin/frpc
armbian-build/userpatches/overlay/usr/local/bin/easytier-core

# 镜像文件
*.img
*.img.xz
*.img.zst

# 编辑器
.vscode/
.idea/
*.swp
*~
